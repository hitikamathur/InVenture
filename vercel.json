{
  "services": {
    "web": {
      "root": ".",
      "buildCommand": "npm run build",
      "outputDirectory": "frontend/dist"
    },
    "api": {
      "root": "api"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": {
        "service": "api"
      }
    },
    {
      "source": "/(.*)",
      "destination": {
        "service": "web"
      }
    }
  ]
}
